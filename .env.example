# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# ============================================
# API Configuration
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# AI Services
# ============================================
# Groq AI API Key - Required for AI Assistant features
# Get your key from: https://console.groq.com/keys
# IMPORTANT: This is exposed to the browser, use a restricted API key
# with limited permissions and rate limiting enabled
NEXT_PUBLIC_GROQ_API_KEY=gsk_your_groq_api_key_here

# ============================================
# Environment
# ============================================
# Set to 'production' for production builds
NODE_ENV=development

# ============================================
# Security Notes
# ============================================
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Only use for non-sensitive configuration
# - Sensitive keys (database, auth secrets) should be backend-only
# - Use .env.local for local development (not committed)
# - Use .env.production for production builds
